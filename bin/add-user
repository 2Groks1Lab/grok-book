#!/bin/bash

# Usage: ./add-user <username> <real-name>
# Example: ./add-user cmenchin "Cody Menchin"

if [ $# -ne 2 ]; then
    echo "Usage: $0 <username> <real-name>"
    exit 1
fi

USERNAME=$1
REALNAME=$2
USER_DIR="users/$USERNAME"
USERS_LIST="users/users.list"

echo "Creating user: $REALNAME ($USERNAME)"

# Create user directory if it doesn't exist
mkdir -p "$USER_DIR"
pushd $USER_DIR

# Create standard symlinks (idempotent)
ln -sfn ../../getting-started "getting-started"
ln -sfn ../../policy          "policy"
ln -sfn ../../docs            "docs"
ln -sfn ../../projects        "projects"

mkdir -p "$USER_DIR/bin/"
ln -sfn ../../sbin            "bin/sbin"

# Add user to users.list if not already present
if [ ! -f "$USERS_LIST" ]; then
    touch "$USERS_LIST"
fi

if ! grep -q "^$USERNAME:" "$USERS_LIST"; then
    echo "$USERNAME:$REALNAME" >> "$USERS_LIST"
    echo "✅ Added $USERNAME to users.list"
else
    echo "ℹ️  $USERNAME already exists in users.list"
fi
popd

echo "✅ User '$USERNAME' created successfully."